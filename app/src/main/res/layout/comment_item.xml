<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp">

    <ImageView
        android:id="@+id/ivAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_profile" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical"
        android:background="@drawable/bg_stat_box"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvAuthorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên tác giả"
            android:textStyle="bold"
            android:textColor="#111827" />

        <TextView
            android:id="@+id/tvContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Nội dung bình luận..."
            android:textColor="#374151" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5 phút trước"
                android:textSize="12sp"
                android:textColor="#9CA3AF" />

            <ImageView
                android:id="@+id/icLike"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_heart" />

            <TextView
                android:id="@+id/tvLikeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0"
                android:textSize="12sp"
                android:textColor="#6B7280" />
                
            <TextView
                android:id="@+id/btnReply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Trả lời"
                android:textSize="12sp"
                android:textColor="#1D4ED8"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
                
            <ImageView
                android:id="@+id/btnMoreOptions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_more_horiz"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Thêm tùy chọn" />
        </LinearLayout>
        
        <TextView
            android:id="@+id/btnViewReplies"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Xem 1 phản hồi"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:textStyle="bold"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
