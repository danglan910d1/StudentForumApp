<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Background Image & Overlay -->
        <ImageView
            android:id="@+id/ivBackground"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_library"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/guideline_half" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="#A6000000"
            app:layout_constraintTop_toTopOf="@id/ivBackground"
            app:layout_constraintBottom_toBottomOf="@id/ivBackground" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_half"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.3" />

        <!-- Header Text Area -->
        <LinearLayout
            android:id="@+id/llHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/cvLoginForm">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student Forum"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <View
                android:layout_width="48dp"
                android:layout_height="3dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nơi tri thức hội tụ và kiến tạo tương lai"
                android:textColor="#E0E0E0"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="HÀNH TRÌNH HỌC THUẬT CỦA BẠN BẮT ĐẦU TẠI ĐÂY"
                android:textColor="#BDBDBD"
                android:textSize="10sp"
                android:letterSpacing="0.05"
                android:textAllCaps="true" />
        </LinearLayout>

        <!-- Main Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvLoginForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="0dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Card.TopRounded"
            app:layout_constraintTop_toBottomOf="@id/guideline_half"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chào mừng trở lại"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Vui lòng đăng nhập để tiếp tục đóng góp cho cộng đồng."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp" />

                <!-- Email Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="EMAIL SINH VIÊN"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputEmailLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="?attr/colorOutlineVariant"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="student@university.edu.vn"
                        android:inputType="textEmailAddress"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password Input -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MẬT KHẨU"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Quên mật khẩu?"
                        android:textColor="?attr/colorSecondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputPasswordLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="?attr/colorOutlineVariant"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="••••••••"
                        android:inputType="textPassword"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Checkbox -->
                <CheckBox
                    android:id="@+id/cbRemember"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Ghi nhớ đăng nhập"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <!-- Login Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="?attr/colorPrimaryContainer"
                    android:textColor="#FFFFFF"
                    android:text="ĐĂNG NHẬP"
                    android:textStyle="bold"
                    android:paddingVertical="12dp"
                    app:cornerRadius="12dp" />

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <View android:layout_width="0dp" android:layout_weight="1" android:layout_height="1dp" android:background="?attr/colorOutlineVariant" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp" android:text="HOẶC ĐĂNG NHẬP BẰNG" android:textSize="10sp" android:textColor="?attr/colorOnSurfaceVariant" />
                    <View android:layout_width="0dp" android:layout_weight="1" android:layout_height="1dp" android:background="?attr/colorOutlineVariant" />
                </LinearLayout>

                <!-- Social Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Google"
                        android:textColor="?attr/colorOnSurface"
                        app:icon="@drawable/ic_google"
                        app:iconTint="@null"
                        app:iconGravity="textStart"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:cornerRadius="12dp"
                        android:paddingVertical="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Facebook"
                        android:textColor="?attr/colorOnSurface"
                        app:icon="@drawable/ic_facebook"
                        app:iconTint="@null"
                        app:iconGravity="textStart"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:cornerRadius="12dp"
                        android:paddingVertical="12dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvRegister"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:text="Chưa có tài khoản? Đăng ký ngay"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp" />

                <!-- Footer -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STUDENT FORUM"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="© 2024 Student Forum. Kết nối tri thức sinh viên."
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:orientation="horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Điều khoản" android:textSize="12sp" android:layout_marginEnd="16dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bảo mật" android:textSize="12sp" android:layout_marginEnd="16dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Liên hệ" android:textSize="12sp" android:layout_marginEnd="16dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trợ giúp" android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>

